      "source": [
        "import pandas as pd\n",
        "\n",
        "def replace_employee_id(employees: pd.DataFrame, employee_uni: pd.DataFrame) -> pd.DataFrame:\n",
        "    df_merged = employees.merge(employee_uni, on='id', how='left')\n",
        "    return df_merged[['unique_id','name']]"
      ]
    }
